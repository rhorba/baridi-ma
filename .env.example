# Baridi.ma — Environment Variables
# Copy to .env.local (never commit real values)

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to false only for local dev without TLS. Leave true (or unset) once deployed behind HTTPS.
COOKIE_SECURE=false

# --- Database (PostgreSQL 16 + TimescaleDB) ---
DATABASE_URL=postgresql://baridi:baridi@localhost:5433/baridi_ma

# --- Auth ---
# Signs/verifies access + refresh JWTs (Auth Service issues, BFF and other services verify)
JWT_SECRET=replace-with-random-32-byte-secret
# Shared secret for BFF -> internal service trust (Security baseline §7 — MVP only, not mTLS)
INTERNAL_SERVICE_TOKEN=replace-with-random-secret
# Auth Service base URL as seen by the BFF (docker-compose overrides this to http://auth-service:4001)
AUTH_SERVICE_URL=http://localhost:4001
# Shipment Service base URL as seen by the BFF (docker-compose overrides this to http://shipment-service:4002)
SHIPMENT_SERVICE_URL=http://localhost:4002
# Ingestion/Alerting Service URLs as seen by Shipment Service (docker-compose overrides these)
INGESTION_SERVICE_URL=http://localhost:4003
ALERTING_SERVICE_URL=http://localhost:4004

# --- Compliance Service ---
# Directory where generated compliance PDFs are stored (docker-compose mounts
# a named volume here; local dev defaults to ./storage inside the service dir)
COMPLIANCE_STORAGE_DIR=./storage

# --- MQTT Broker (IoT sensor ingestion) ---
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Payments (CMI) — STUBBED for MVP, not wired until sandbox credentials exist ---
# CMI_MERCHANT_ID=
# CMI_STORE_KEY=
# CMI_API_URL=
